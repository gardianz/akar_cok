{
  "apiBaseUrl": "https://api.walley.cc",
  "webBaseUrl": "https://walley.cc",
  "requestTimeoutMs": 30000,
  "loginConcurrency": 3,
  "sessionMode": "browser-session",
  "transferMode": "manual",
  "ensureTransferPreapproval": false,
  "verifyAfterSubmit": true,
  "verificationPollIntervalMs": 3000,
  "verificationPollAttempts": 8,
  "interTransferDelayMs": 1000,
  "autoAcceptPendingTransfers": true,
  "pendingTransferPollIntervalMs": 4000,
  "pendingTransferPollAttempts": 6,
  "postAcceptTransferDelayMinMs": 3000,
  "postAcceptTransferDelayMaxMs": 8000,
  "browserChannel": "chrome",
  "browserHeadless": true,
  "browserNavigationTimeoutMs": 45000,
  "browserActionTimeoutMs": 15000,
  "bootstrapMissingSession": true,
  "keepBrowserOpen": false
}
